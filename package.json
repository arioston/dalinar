{
  "name": "dalinar",
  "private": true,
  "version": "0.1.0",
  "description": "The Bondsmith — unifying Jasnah (memory) and Sazed (planning) into a cohesive AI-augmented development workflow",
  "workspaces": [
    "packages/*",
    "modules/jasnah",
    "modules/sazed/packages/*",
    "modules/hoid/packages/*"
  ],
  "scripts": {
    "test:unit": "bun test packages/",
    "test:smoke": "bun test packages/orchestrator/src/effect/sazed-smoke.test.ts",
    "test:exports": "bun test packages/orchestrator/src/effect/sazed-exports.test.ts",
    "test:hermetic": "bun test packages/ --bail",
    "test:live": "RUN_EXTERNAL_TESTS=1 bun test packages/orchestrator/src/effect/sazed-contract.test.ts",
    "test:contract": "RUN_EXTERNAL_TESTS=1 bun test packages/orchestrator/src/effect/sazed-contract.test.ts",
    "test:all": "RUN_EXTERNAL_TESTS=1 bun test packages/",
    "ci:clean-check": "bash scripts/ci-clean-check.sh",
    "ci:required": "bun run test:hermetic && bun run test:smoke && bun run test:exports && bun run ci:clean-check",
    "ci:contract": "bun run test:live",
    "ci:preflight": "bun run packages/orchestrator/src/effect/doctor-cli.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "overrides": {
    "effect": "^3.19.19"
  }
}
