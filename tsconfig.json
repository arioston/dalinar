{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@dalinar/protocol": ["./packages/protocol/src"],
      "@dalinar/orchestrator": ["./packages/orchestrator/src"]
    }
  },
  "references": [
    { "path": "./packages/protocol" },
    { "path": "./packages/orchestrator" }
  ]
}
